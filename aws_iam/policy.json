{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AllowSSMAccess",
            "Effect": "Allow",
            "Action": [
                "ssm:GetConnectionStatus",
                "ssm:ResumeSession",
                "ec2:DescribeInstances",
                "ssm:DescribeSessions",
                "ssm:TerminateSession",
                "ssm:StartSession"
            ],
            "Resource": [
                "arn:aws:ssm:*:046219898673:document/SSM-SessionManagerRunShell",
                "arn:aws:ec2:*:046219898673:instance/*"
            ]
        },
        {
            "Sid": "AllowAnsibleS3BucketAccess",
            "Effect": "Allow",
            "Action": [
                "s3:PutObject",
                "s3:GetObject",
                "s3:DeleteObject",
                "s3:ListBucket",
                "s3:GetBucketLocation"
            ],
            "Resource": [
                "arn:aws:s3:::teste-poc-estudo",
                "arn:aws:s3:::teste-poc-estudo/*"
            ]
        }
    ]
}